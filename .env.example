# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/vetcore
# або окремими полями (DATABASE_URL має пріоритет):
PGHOST=localhost
PGPORT=5432
PGDATABASE=vetcore
PGUSER=
PGPASSWORD=

# Auth
JWT_SECRET=change-me-in-production-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Seed (перший суперкористувач / власник клініки)
SEED_ADMIN_EMAIL=admin@vetcore.local
SEED_ADMIN_PASSWORD=admin12345
