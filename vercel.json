{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/uploads/(.*)", "dest": "/api/index.js" },
    { "src": "/css/(.*)", "dest": "/frontend/css/$1" },
    { "src": "/js/(.*)", "dest": "/frontend/js/$1" },
    { "src": "/assets/(.*)", "dest": "/frontend/assets/$1" },
    { "src": "/manifest.json", "dest": "/frontend/manifest.json" },
    { "src": "/sw.js", "dest": "/frontend/sw.js" },
    { "src": "/index.html", "dest": "/frontend/index.html" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ]
}
